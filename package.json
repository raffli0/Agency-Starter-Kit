{
  "name": "agency-starter-kit",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "npm run build && wrangler dev",
    "astro": "astro",
    "check": "astro check",
    "lint": "eslint src/lib src/config src/data src/types src/constants",
    "format": "prettier --write \"src/**/*.{astro,ts,js}\" \"*.{json,md,yml,yaml}\"",
    "format:check": "prettier --check \"src/**/*.{astro,ts,js}\" \"*.{json,md,yml,yaml}\"",
    "generate-types": "wrangler types",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^14.1.4",
    "@astrojs/mdx": "^7.0.3",
    "@astrojs/sitemap": "^3.7.3",
    "@fontsource-variable/inter": "^5.2.8",
    "@tailwindcss/vite": "^4.3.3",
    "astro": "^7.1.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-astro": "^0.556.0",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.3.3",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@biomejs/biome": "^1.9.4",
    "eslint": "^9.18.0",
    "eslint-plugin-astro": "^1.3.1",
    "prettier": "^3.9.5",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "wrangler": "^4.113.0"
  }
}
