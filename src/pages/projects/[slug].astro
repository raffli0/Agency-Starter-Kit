---
import type { GetStaticPaths } from "astro";
import type { CollectionEntry } from "astro:content";
import { getCollection, getEntry, render } from "astro:content";
import ArticleLayout from "../../layouts/ArticleLayout.astro";
import Cta from "../../components/sections/Cta.astro";
import { useTranslations, localizePath } from "../../i18n/utils";
import type { Locale } from "../../i18n/config";

export const getStaticPaths = (async () => {
    const entries: CollectionEntry<"projects">[] = await getCollection("projects");
    return entries.map((entry) => ({
        params: { slug: entry.id },
    }));
}) satisfies GetStaticPaths;

const locale: Locale = "en";
const t = useTranslations(locale);

const { slug } = Astro.params;
const entry = await getEntry("projects", slug!);
if (!entry) return Astro.redirect("/404");

const { Content } = await render(entry);
---

<ArticleLayout title={entry.data.title} description={entry.data.description} locale={locale}>
    <a
        href={localizePath("/projects", locale)}
        class="text-xs font-medium tracking-[0.12em] text-muted-foreground uppercase transition-colors duration-150 hover:text-foreground"
        >← {t("projects.back")}</a
    >
    <div class="mt-6 flex items-start justify-between gap-4">
        <h1 class="text-4xl font-semibold tracking-tight text-foreground">{entry.data.title}</h1>
        <span
            class="shrink-0 border border-border px-2.5 py-1 text-[11px] tracking-[0.06em] text-muted-foreground uppercase"
        >
            {entry.data.category}
        </span>
    </div>
    <p class="mt-3 text-muted-foreground">{entry.data.description}</p>
    <article class="prose mt-8 max-w-none">
        <Content />
    </article>
    <Cta
        title={t("projects.similar")}
        ctaLabel={t("home.cta.label")}
        ctaHref={localizePath("/contact", locale)}
    />
</ArticleLayout>
