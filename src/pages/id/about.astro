---
import PageLayout from "../../layouts/PageLayout.astro";
import Container from "../../components/ui/Container.astro";
import Team from "../../components/sections/Team.astro";
import Timeline from "../../components/sections/Timeline.astro";
import Stats from "../../components/sections/Stats.astro";
import Cta from "../../components/sections/Cta.astro";
import { teamByLocale } from "../../data/team";
import { timelineByLocale } from "../../data/timeline";
import { statsByLocale } from "../../data/stats";
import { useTranslations, localizePath } from "../../i18n/utils";
import type { Locale } from "../../i18n/config";

const locale: Locale = "id";
const t = useTranslations(locale);
---

<PageLayout title={t("about.title")} description={t("about.description")} locale={locale}>
    <Container class="py-16">
        <h1 class="text-4xl font-semibold tracking-tight text-foreground">{t("about.title")}</h1>
        <p class="mt-6 max-w-2xl text-base leading-7 text-muted-foreground sm:text-lg">
            {t("about.intro")}
        </p>
        <Stats group={statsByLocale(locale)} />
        <Team title={t("about.team.title")} team={teamByLocale(locale)} />
        <Timeline title={t("about.timeline.title")} entries={timelineByLocale(locale)} />
        <Cta
            title={t("about.cta.title")}
            description={t("about.cta.description")}
            ctaLabel={t("home.cta.label")}
            ctaHref={localizePath("/contact", locale)}
        />
    </Container>
</PageLayout>
