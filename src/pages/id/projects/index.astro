---
import type { CollectionEntry } from "astro:content";
import { getCollection } from "astro:content";
import PageLayout from "../../../layouts/PageLayout.astro";
import Container from "../../../components/ui/Container.astro";
import ProjectCard from "../../../components/cards/ProjectCard.astro";
import Cta from "../../../components/sections/Cta.astro";
import { useTranslations, localizePath } from "../../../i18n/utils";
import type { Locale } from "../../../i18n/config";

const locale: Locale = "id";
const t = useTranslations(locale);

const entries: CollectionEntry<"projects">[] = await getCollection("projects");
const projects = entries.map((entry) => ({
    ...entry.data,
    slug: entry.id,
}));
---

<PageLayout title={t("projects.title")} description={t("projects.description")} locale={locale}>
    <Container class="py-16">
        <h1 class="text-foreground text-4xl font-semibold tracking-tight">{t("projects.title")}</h1>
        <p class="text-muted-foreground mt-6 max-w-2xl text-base leading-7 sm:text-lg">
            {t("projects.intro")}
        </p>
        <div class="bg-border-primary mt-10 grid gap-px sm:grid-cols-2">
            {projects.map((project) => <ProjectCard project={project} />)}
        </div>
        <Cta
            title={t("projects.cta")}
            ctaLabel={t("home.cta.label")}
            ctaHref={localizePath("/contact", locale)}
        />
    </Container>
</PageLayout>
