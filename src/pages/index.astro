---
import PageLayout from "../layouts/PageLayout.astro";
import Hero from "../components/sections/Hero.astro";
import Services from "../components/sections/Services.astro";
import Testimonials from "../components/sections/Testimonials.astro";
import Cta from "../components/sections/Cta.astro";
import Brands from "../components/sections/Brands.astro";
import Container from "../components/ui/Container.astro";
import Button from "@/components/ui/button.astro";
import { siteConfig } from "../config/site";
import { services } from "../data/services";
import { testimonials } from "../data/testimonials";
import { brands } from "../data/brands";
import type { HeroConfig } from "../types/hero";

const hero: HeroConfig = {
    eyebrow: siteConfig.name,
    heading: "Creative digital experiences for modern agencies.",
    subtext:
        "Launch a performant, accessible site with Astro, Tailwind CSS, MDX, and sitemap generation.",
    primaryAction: { label: "Get started", href: "/contact", variant: "primary" },
    secondaryAction: { label: "Our services", href: "/services", variant: "secondary" },
    stats: [
        { label: "Projects shipped", value: "120+" },
        { label: "Happy clients", value: "60+" },
        { label: "Performance score", value: "98" },
        { label: "Years in business", value: "8" },
    ],
};
---

<PageLayout title={siteConfig.title} description={siteConfig.description}>
    <Container class="py-16">
        <Hero hero={hero} />
        <Services services={services} />
        <Testimonials testimonials={testimonials} />
        <Brands brands={brands} />
        <Cta />
        <!-- contoh pakai button -->
         <div class="mt-12 flex gap-4">
            <Button
                href="/contact"
                size="lg"
                variant="destructive"
            >Get Started Destructive</Button>
            <Button
                href="/contact"
                size="lg"
                variant="default"
            >Get Started Default</Button>
            <Button
                href="/contact"
                size="lg"
                variant="ghost"
            >Get Started Ghost</Button>
            <Button
                href="/contact"
                size="lg"
                variant="outline"
            >Get Started Outline</Button>
         </div>
    </Container>
</PageLayout>
