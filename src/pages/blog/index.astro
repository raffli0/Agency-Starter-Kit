---
import type { CollectionEntry } from "astro:content";
import { getCollection } from "astro:content";
import PageLayout from "../../layouts/PageLayout.astro";
import Container from "../../components/ui/Container.astro";
import PostCard from "../../components/cards/PostCard.astro";
import Cta from "../../components/sections/Cta.astro";
import { useTranslations, localizePath } from "../../i18n/utils";
import type { Locale } from "../../i18n/config";

const locale: Locale = "en";
const t = useTranslations(locale);

const entries: CollectionEntry<"blog">[] = await getCollection(
    "blog",
    ({ data }: { data: { draft?: boolean } }) => !data.draft,
);
const posts = entries
    .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
    .map((entry) => ({
        title: entry.data.title,
        description: entry.data.description,
        slug: entry.id,
        publishedAt: entry.data.publishedAt,
        author: entry.data.author,
        tags: entry.data.tags,
        cover: entry.data.cover,
    }));
---

<PageLayout title={t("blog.title")} description={t("blog.description")} locale={locale}>
    <Container class="py-16">
        <h1 class="text-foreground text-4xl font-semibold tracking-tight">{t("blog.title")}</h1>
        <p class="text-muted-foreground mt-6 max-w-2xl text-base leading-7 sm:text-lg">
            {t("blog.intro")}
        </p>
        <div class="bg-border-primary mt-10 grid gap-px md:grid-cols-2 lg:grid-cols-3">
            {posts.map((post) => <PostCard post={post} />)}
        </div>
        <Cta
            title={t("blog.cta.title")}
            description={t("blog.cta.description")}
            ctaLabel={t("home.cta.label")}
            ctaHref={localizePath("/contact", locale)}
        />
    </Container>
</PageLayout>
