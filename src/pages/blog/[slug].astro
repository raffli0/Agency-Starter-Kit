---
import type { GetStaticPaths } from "astro";
import type { CollectionEntry } from "astro:content";
import { getCollection, getEntry, render } from "astro:content";
import ArticleLayout from "../../layouts/ArticleLayout.astro";

export const getStaticPaths = (async () => {
    const entries: CollectionEntry<"blog">[] = await getCollection(
        "blog",
        ({ data }: { data: { draft?: boolean } }) => !data.draft,
    );
    return entries.map((entry) => ({
        params: { slug: entry.id },
    }));
}) satisfies GetStaticPaths;

const { slug } = Astro.params;
const entry = await getEntry("blog", slug!);
if (!entry) return Astro.redirect("/404");

const { Content } = await render(entry);
const formatted = entry.data.publishedAt.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
});
---

<ArticleLayout title={entry.data.title} description={entry.data.description}>
    <a href="/blog" class="text-sm text-sky-300 hover:text-sky-200">← Back to blog</a>
    <h1 class="mt-6 text-4xl font-semibold text-white">{entry.data.title}</h1>
    <p class="mt-4 text-sm text-slate-500">{formatted} · {entry.data.author}</p>
    <article class="prose prose-invert mt-8 max-w-none">
        <Content />
    </article>
</ArticleLayout>
