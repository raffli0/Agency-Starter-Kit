---
import type { GetStaticPaths } from "astro";
import type { CollectionEntry } from "astro:content";
import { getCollection, getEntry, render } from "astro:content";
import ArticleLayout from "../../layouts/ArticleLayout.astro";
import { useTranslations, localizePath } from "../../i18n/utils";
import type { Locale } from "../../i18n/config";

export const getStaticPaths = (async () => {
    const entries: CollectionEntry<"blog">[] = await getCollection(
        "blog",
        ({ data }: { data: { draft?: boolean } }) => !data.draft,
    );
    return entries.map((entry) => ({
        params: { slug: entry.id },
    }));
}) satisfies GetStaticPaths;

const locale: Locale = "en";
const t = useTranslations(locale);

const { slug } = Astro.params;
const entry = await getEntry("blog", slug!);
if (!entry) return Astro.redirect("/404");

const { Content } = await render(entry);
const formatted = entry.data.publishedAt.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
});
---

<ArticleLayout title={entry.data.title} description={entry.data.description} locale={locale}>
    <a
        href={localizePath("/blog", locale)}
        class="text-xs font-medium tracking-[0.12em] text-muted-foreground uppercase transition-colors duration-150 hover:text-foreground"
        >← {t("blog.back")}</a
    >
    {
        entry.data.cover && (
            <img
                src={entry.data.cover}
                alt=""
                width="800"
                height="450"
                loading="eager"
                decoding="async"
                class="mt-6 aspect-video w-full rounded object-cover"
            />
        )
    }
    <h1 class="mt-6 text-4xl font-semibold tracking-tight text-foreground">{entry.data.title}</h1>
    <p class="mt-4 text-xs tracking-[0.08em] text-muted-foreground uppercase">
        {formatted} · {entry.data.author}
    </p>
    <article class="prose mt-8 max-w-none">
        <Content />
    </article>
</ArticleLayout>
