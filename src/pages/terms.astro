---
import PageLayout from "../layouts/PageLayout.astro";
import Container from "../components/ui/Container.astro";
import { siteConfig } from "../config/site";
import { useTranslations } from "../i18n/utils";
import type { Locale } from "../i18n/config";

const locale: Locale = "en";
const t = useTranslations(locale);
---

<PageLayout title={t("terms.title")} description={t("terms.description")} locale={locale}>
    <Container class="py-16">
        <h1 class="text-4xl font-semibold tracking-tight text-foreground">{t("terms.title")}</h1>
        <p class="mt-6 text-xs tracking-[0.08em] text-muted-foreground uppercase">
            {t("terms.updated")}: {new Date().getFullYear()}
        </p>

        <div class="mt-8 max-w-2xl space-y-8 text-muted-foreground">
            <p>{t("terms.intro")}</p>
            <section>
                <h2 class="text-xl font-semibold tracking-tight text-foreground">
                    {t("terms.use.title")}
                </h2>
                <p class="mt-3 text-sm leading-6">{t("terms.use.body")}</p>
            </section>
            <section>
                <h2 class="text-xl font-semibold tracking-tight text-foreground">
                    {t("terms.liability.title")}
                </h2>
                <p class="mt-3 text-sm leading-6">{t("terms.liability.body")}</p>
            </section>
            <section>
                <h2 class="text-xl font-semibold tracking-tight text-foreground">
                    {t("terms.contact.title")}
                </h2>
                <p class="mt-3 text-sm leading-6">
                    {t("terms.contact.body")}
                    <a
                        href={`mailto:${siteConfig.email}`}
                        class="text-brand transition-colors duration-150 hover:text-foreground"
                    >
                        {siteConfig.email}
                    </a>.
                </p>
            </section>
            <p class="text-xs text-muted-foreground">{t("terms.placeholder")}</p>
        </div>
    </Container>
</PageLayout>
