---
import PageLayout from "../layouts/PageLayout.astro";
import Container from "../components/ui/Container.astro";
import { siteConfig } from "../config/site";
---

<PageLayout title="Terms of Service" description="The terms governing your use of this website.">
    <Container>
        <h1 class="text-4xl font-semibold text-white">Terms of Service</h1>
        <p class="mt-6 text-sm text-slate-500">Last updated: {new Date().getFullYear()}</p>

        <div class="mt-8 space-y-6 text-slate-300">
            <p>
                These Terms of Service govern your use of the {siteConfig.name} website. By accessing
                the site, you agree to these terms.
            </p>
            <section>
                <h2 class="text-xl font-semibold text-white">Use of the site</h2>
                <p class="mt-3">
                    You agree to use the site lawfully and not to engage in activity that disrupts
                    or harms the service or other users.
                </p>
            </section>
            <section>
                <h2 class="text-xl font-semibold text-white">Limitation of liability</h2>
                <p class="mt-3">
                    The site is provided "as is" without warranties of any kind. We are not liable
                    for indirect or consequential damages arising from its use.
                </p>
            </section>
            <section>
                <h2 class="text-xl font-semibold text-white">Contact</h2>
                <p class="mt-3">
                    Questions? Email
                    <a href={`mailto:${siteConfig.email}`} class="text-sky-300 hover:text-sky-200">
                        {siteConfig.email}
                    </a>.
                </p>
            </section>
            <p class="text-sm text-slate-500">
                Replace this placeholder with a reviewed, jurisdiction-appropriate document before
                launch.
            </p>
        </div>
    </Container>
</PageLayout>
