---
import PageLayout from "../layouts/PageLayout.astro";
import Container from "../components/ui/Container.astro";
import { siteConfig } from "../config/site";
---

<PageLayout title="Privacy Policy" description="How we collect, use, and protect your data.">
    <Container>
        <h1 class="text-4xl font-semibold text-white">Privacy Policy</h1>
        <p class="mt-6 text-sm text-slate-500">Last updated: {new Date().getFullYear()}</p>

        <div class="mt-8 space-y-6 text-slate-300">
            <p>
                This Privacy Policy explains how {siteConfig.name} ("we", "us") collects, uses, and protects
                your information when you use this website.
            </p>
            <section>
                <h2 class="text-xl font-semibold text-white">Information we collect</h2>
                <p class="mt-3">
                    We may collect information you provide directly, such as your name and email
                    when you contact us, as well as anonymous analytics about how the site is used.
                </p>
            </section>
            <section>
                <h2 class="text-xl font-semibold text-white">How we use information</h2>
                <p class="mt-3">
                    Information is used to respond to inquiries, improve the site, and communicate
                    with you when you have opted in.
                </p>
            </section>
            <section>
                <h2 class="text-xl font-semibold text-white">Contact</h2>
                <p class="mt-3">
                    Questions? Email
                    <a href={`mailto:${siteConfig.email}`} class="text-sky-300 hover:text-sky-200">
                        {siteConfig.email}
                    </a>.
                </p>
            </section>
            <p class="text-sm text-slate-500">
                Replace this placeholder policy with a reviewed, jurisdiction-appropriate document
                before launch.
            </p>
        </div>
    </Container>
</PageLayout>
