---
import { siteConfig } from "../../config/site";
import { formatPhone } from "../../lib/format";
import { type Locale } from "../../i18n/config";
import { useTranslations, localizePath } from "../../i18n/utils";

interface Props {
    locale?: Locale;
}

const locale = Astro.props.locale ?? "en";
const t = useTranslations(locale);

const footerNavigation = [
    {
        title: t("footer.company"),
        items: [
            { label: t("nav.about"), href: localizePath("/about", locale) },
            { label: t("nav.projects"), href: localizePath("/projects", locale) },
            { label: t("nav.blog"), href: localizePath("/blog", locale) },
        ],
    },
    {
        title: t("footer.legal"),
        items: [
            { label: t("footer.privacy"), href: localizePath("/privacy-policy", locale) },
            { label: t("footer.terms"), href: localizePath("/terms", locale) },
        ],
    },
];
---

<footer class="mt-24 border-t border-border bg-background">
    <div
        class="mx-auto grid max-w-6xl gap-10 px-6 py-16 sm:grid-cols-2 sm:px-8 lg:grid-cols-3 lg:px-10"
    >
        <div>
            <p class="text-xs font-semibold tracking-[0.2em] text-foreground uppercase">
                {siteConfig.name}
            </p>
            <p class="mt-4 max-w-sm text-sm leading-6 text-muted-foreground">
                {t("site.description")}
            </p>
            <div class="mt-6 flex flex-col gap-2 text-sm">
                <a
                    href={`mailto:${siteConfig.email}`}
                    class="text-muted-foreground transition-colors duration-150 hover:text-foreground"
                >
                    {siteConfig.email}
                </a>
                <a
                    href={`tel:${formatPhone(siteConfig.phone)}`}
                    class="text-muted-foreground transition-colors duration-150 hover:text-foreground"
                >
                    {siteConfig.phone}
                </a>
            </div>
        </div>

        {
            footerNavigation.map((section) => (
                <div>
                    <p class="text-xs font-semibold tracking-[0.16em] text-foreground uppercase">
                        {section.title}
                    </p>
                    <ul class="mt-4 space-y-2 text-sm">
                        {section.items.map((item) => (
                            <li>
                                <a
                                    href={item.href}
                                    class="text-muted-foreground transition-colors duration-150 hover:text-foreground"
                                >
                                    {item.label}
                                </a>
                            </li>
                        ))}
                    </ul>
                </div>
            ))
        }
    </div>
    <div class="border-t border-border">
        <div
            class="mx-auto max-w-6xl px-6 py-6 text-xs tracking-wide text-muted-foreground sm:px-8 lg:px-10"
        >
            {siteConfig.copyright}
        </div>
    </div>
</footer>
