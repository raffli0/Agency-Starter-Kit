---
import { footerNavigation } from "../../config/navigation";
import { siteConfig } from "../../config/site";
import { formatPhone } from "../../lib/format";
---

<footer class="mt-24 border-t border-slate-800 bg-slate-950">
    <div
        class="mx-auto grid max-w-6xl gap-10 px-6 py-12 sm:grid-cols-2 sm:px-8 lg:grid-cols-3 lg:px-10"
    >
        <div>
            <p class="text-sm font-semibold tracking-[0.24em] text-sky-400 uppercase">
                {siteConfig.name}
            </p>
            <p class="mt-4 max-w-sm text-sm text-slate-400">{siteConfig.description}</p>
            <div class="mt-6 flex flex-col gap-2 text-sm">
                <a
                    href={`mailto:${siteConfig.email}`}
                    class="text-slate-300 transition hover:text-white"
                >
                    {siteConfig.email}
                </a>
                <a
                    href={`tel:${formatPhone(siteConfig.phone)}`}
                    class="text-slate-300 transition hover:text-white"
                >
                    {siteConfig.phone}
                </a>
            </div>
        </div>

        {
            footerNavigation.map((section) => (
                <div>
                    <p class="text-sm font-semibold text-white capitalize">{section.title}</p>
                    <ul class="mt-4 space-y-2 text-sm">
                        {section.items.map((item) => (
                            <li>
                                <a
                                    href={item.href}
                                    class="text-slate-400 transition hover:text-white"
                                >
                                    {item.label}
                                </a>
                            </li>
                        ))}
                    </ul>
                </div>
            ))
        }
    </div>
    <div class="border-t border-slate-800">
        <div class="mx-auto max-w-6xl px-6 py-6 text-sm text-slate-500 sm:px-8 lg:px-10">
            {siteConfig.copyright}
        </div>
    </div>
</footer>
