---
import Container from "../ui/Container.astro";
import Button from "../ui/button.astro";
import LanguageToggle from "./LanguageToggle.astro";
import ThemeToggle from "./ThemeToggle.astro";
import { siteConfig } from "../../config/site";
import { type Locale } from "../../i18n/config";
import { useTranslations, localizePath } from "../../i18n/utils";
import { Menu, X } from "lucide-astro";

interface Props {
    locale?: Locale;
}

const locale = Astro.props.locale ?? "en";
const t = useTranslations(locale);

const navigation = [
    { label: t("nav.home"), href: localizePath("/", locale) },
    { label: t("nav.about"), href: localizePath("/about", locale) },
    { label: t("nav.services"), href: localizePath("/services", locale) },
    { label: t("nav.projects"), href: localizePath("/projects", locale) },
    { label: t("nav.blog"), href: localizePath("/blog", locale) },
    { label: t("nav.contact"), href: localizePath("/contact", locale) },
];
---

<header
    id="site-header"
    class="border-border bg-background/90 sticky top-0 z-50 border-b backdrop-blur-sm"
>
    <Container>
        <div class="flex h-16 items-center justify-between gap-6">
            <a
                href={localizePath("/", locale)}
                class="group flex shrink-0 items-center gap-2 md:flex-1"
            >
                <span
                    class="text-sm font-semibold tracking-tight uppercase transition-opacity group-hover:opacity-60"
                >
                    {siteConfig.name}
                </span>
            </a>

            <nav class="hidden flex-1 justify-center md:flex">
                <ul class="flex items-center gap-0" id="desktop-nav">
                    {
                        navigation.map((item) => (
                            <li>
                                <a
                                    href={item.href}
                                    data-href={item.href}
                                    class="nav-link text-muted-foreground hover:text-foreground [&.is-active]:text-foreground [&.is-active]:after:bg-foreground relative flex min-h-11 items-center justify-center px-4 py-2 text-xs font-medium tracking-[0.12em] uppercase transition-colors duration-150 [&.is-active]:after:absolute [&.is-active]:after:right-4 [&.is-active]:after:bottom-1 [&.is-active]:after:left-4 [&.is-active]:after:h-px"
                                >
                                    <span class="relative z-10">{item.label}</span>
                                </a>
                            </li>
                        ))
                    }
                </ul>
            </nav>

            <div class="flex shrink-0 items-center justify-end gap-2 md:flex-1">
                <ThemeToggle locale={locale} />
                <div class="hidden sm:block">
                    <LanguageToggle locale={locale} />
                </div>
                <Button
                    variant="ghost"
                    size="icon"
                    id="menu-toggle"
                    aria-label={t("nav.toggle")}
                    aria-expanded="false"
                    class="border-input relative h-11 w-11 border md:hidden"
                >
                    <Menu class="h-4 w-4" id="icon-menu" />
                    <X class="hidden h-4 w-4" id="icon-close" />
                </Button>
            </div>
        </div>
    </Container>

    <div
        id="mobile-menu"
        class="border-border hidden overflow-hidden border-t md:hidden"
        style="height: 0;"
    >
        <Container>
            <nav class="py-3">
                <ul class="flex flex-col gap-0.5" id="mobile-nav">
                    {
                        navigation.map((item) => (
                            <li>
                                <a
                                    href={item.href}
                                    data-href={item.href}
                                    class="mobile-nav-link text-muted-foreground hover:text-foreground [&.is-active]:text-foreground flex min-h-11 items-center gap-3 px-1 py-3 text-xs font-medium tracking-[0.12em] uppercase transition-colors"
                                >
                                    <span class="nav-dot bg-border h-1 w-1 transition-colors" />
                                    {item.label}
                                </a>
                            </li>
                        ))
                    }
                </ul>
                <div class="border-border flex items-center gap-3 border-t py-4 sm:hidden">
                    <LanguageToggle locale={locale} />
                </div>
            </nav>
        </Container>
    </div>
</header>

<style>
    #mobile-menu {
        transition:
            height 0.2s ease-in-out,
            opacity 0.2s ease-in-out;
        overflow: hidden;
    }
    #mobile-menu.wa-open {
        height: auto !important;
        opacity: 1 !important;
    }
</style>

<script>
    const menuToggle = document.getElementById("menu-toggle");
    const mobileMenu = document.getElementById("mobile-menu");
    const iconMenu = document.getElementById("icon-menu");
    const iconClose = document.getElementById("icon-close");
    const pathName = window.location.pathname;

    const links = Array.from(document.querySelectorAll<HTMLAnchorElement>("[data-href]"));
    links.forEach((link) => {
        const href = link.getAttribute("data-href") || "";
        const active =
            href === pathName || (href !== "/" && href !== "/id" && pathName.startsWith(href));
        link.classList.toggle("is-active", active);
        const dot = link.querySelector(".nav-dot");
        dot?.classList.toggle("bg-foreground", active);
        dot?.classList.toggle("bg-border", !active);
    });

    function setMenu(open: boolean) {
        menuToggle?.setAttribute("aria-expanded", String(open));
        iconMenu?.classList.toggle("hidden", open);
        iconClose?.classList.toggle("hidden", !open);
        if (!mobileMenu) return;
        mobileMenu.classList.remove("hidden");
        if (open) {
            mobileMenu.style.height = "0px";
            mobileMenu.style.opacity = "0";
            requestAnimationFrame(() => {
                mobileMenu.style.height = mobileMenu.scrollHeight + "px";
                mobileMenu.style.opacity = "1";
            });
        } else {
            mobileMenu.style.height = mobileMenu.scrollHeight + "px";
            requestAnimationFrame(() => {
                mobileMenu.style.height = "0px";
                mobileMenu.style.opacity = "0";
            });
        }
    }
    menuToggle?.addEventListener("click", () => {
        const isOpen = menuToggle.getAttribute("aria-expanded") === "true";
        setMenu(!isOpen);
    });

    window.addEventListener("astro:after-swap", () => setMenu(false));
    links.forEach((l) => l.addEventListener("click", () => setMenu(false)));
</script>
