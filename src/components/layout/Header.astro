---
import { navigation } from "../../config/navigation";
import { siteConfig } from "../../config/site";
---

<header class="sticky top-0 z-50 border-b border-slate-800 bg-slate-950/80 backdrop-blur">
    <div
        class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-6 py-4 sm:px-8 lg:px-10"
    >
        <a href="/" class="text-sm font-semibold tracking-[0.24em] text-sky-400 uppercase">
            {siteConfig.name}
        </a>
        <nav class="flex flex-wrap items-center gap-6 text-sm">
            {
                navigation.map((item) => (
                    <a href={item.href} class="text-slate-300 transition hover:text-white">
                        {item.label}
                    </a>
                ))
            }
        </nav>
    </div>
</header>
