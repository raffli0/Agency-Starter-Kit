---
import type { Testimonial } from "../../types/testimonial";
import TestimonialCard from "../cards/TestimonialCard.astro";

interface Props {
    title?: string;
    testimonials: Testimonial[];
}

const { title = "Trusted by teams we work with", testimonials } = Astro.props;
---

<section class="mt-20">
    <div class="flex items-end justify-between gap-4 border-b border-border pb-4">
        <h2 class="text-2xl font-semibold tracking-tight text-foreground">{title}</h2>
        <span class="hidden text-xs tracking-[0.16em] text-muted-foreground uppercase sm:block">
            02
        </span>
    </div>
    <div class="mt-8 grid gap-px bg-border md:grid-cols-3">
        {testimonials.map((item) => <TestimonialCard testimonial={item} />)}
    </div>
</section>
