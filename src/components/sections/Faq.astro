---
import type { FAQItem } from "../../types/faq";

interface Props {
    title?: string;
    items: FAQItem[];
}

const { title = "Frequently asked questions", items } = Astro.props;
---

<section class="mt-20">
    <div class="flex items-end justify-between gap-4 border-b border-border pb-4">
        <h2 class="text-2xl font-semibold tracking-tight text-foreground">{title}</h2>
    </div>
    <div class="mt-8 space-y-0 border border-border">
        {
            items.map((item) => (
                <details class="border-b border-border last:border-b-0">
                    <summary class="cursor-pointer px-6 py-5 font-medium tracking-tight text-foreground transition-colors duration-150 hover:bg-secondary/50">
                        {item.question}
                    </summary>
                    <p class="px-6 pb-5 text-sm leading-6 text-muted-foreground">{item.answer}</p>
                </details>
            ))
        }
    </div>
</section>
