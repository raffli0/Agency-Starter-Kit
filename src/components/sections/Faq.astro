---
import type { FAQItem } from "../../types/faq";

interface Props {
    title?: string;
    items: FAQItem[];
}

const { title = "Frequently asked questions", items } = Astro.props;
---

<section class="mt-20">
    <h2 class="text-2xl font-semibold text-white">{title}</h2>
    <div class="mt-6 space-y-4">
        {
            items.map((item) => (
                <details class="rounded-3xl border border-slate-800 bg-slate-900/80 p-6 shadow-xl shadow-slate-950/20">
                    <summary class="cursor-pointer font-semibold text-white">
                        {item.question}
                    </summary>
                    <p class="mt-3 text-sm text-slate-400">{item.answer}</p>
                </details>
            ))
        }
    </div>
</section>
