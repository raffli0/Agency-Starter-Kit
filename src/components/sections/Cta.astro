---
interface Props {
    title?: string;
    description?: string;
    ctaLabel?: string;
    ctaHref?: string;
}

const {
    title = "Ready to build?",
    description = "Update src/config/site.ts with your details, then deploy to any static host.",
    ctaLabel = "Contact us",
    ctaHref = "/contact",
} = Astro.props;
---

<section
    class="mt-20 rounded-3xl border border-slate-800 bg-slate-900/80 p-10 text-center shadow-xl shadow-slate-950/20"
>
    <h2 class="text-3xl font-semibold text-white">{title}</h2>
    <p class="mx-auto mt-3 max-w-xl text-slate-300">{description}</p>
    <a
        href={ctaHref}
        class="mt-6 inline-flex items-center justify-center rounded-full bg-white px-6 py-3 text-sm font-semibold text-slate-950 transition hover:bg-slate-100"
        >{ctaLabel}</a
    >
</section>
