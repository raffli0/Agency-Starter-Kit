---
interface Props {
    title?: string;
    description?: string;
    ctaLabel?: string;
    ctaHref?: string;
}

const {
    title = "Ready to build?",
    description = "Update src/config/site.ts with your details, then deploy to any static host.",
    ctaLabel = "Contact us",
    ctaHref = "/contact",
} = Astro.props;
---

<section class="mt-20 border border-border bg-primary p-10 text-center text-primary-foreground sm:p-14">
    <h2 class="text-3xl font-semibold tracking-tight">{title}</h2>
    <p class="mx-auto mt-3 max-w-xl text-sm leading-6 text-primary-foreground/70">{description}</p>
    <a
        href={ctaHref}
        class="mt-8 inline-flex cursor-pointer items-center justify-center bg-background px-6 py-3 text-sm font-medium text-foreground transition-opacity duration-150 hover:opacity-90"
        >{ctaLabel}</a
    >
</section>
