---
import type { ServiceItem } from "../../types/service";
import ServiceCard from "../cards/ServiceCard.astro";
import Reveal from "../animation/Reveal.astro";

interface Props {
    title?: string;
    services: ServiceItem[];
}

const { title = "What we do", services } = Astro.props;
---

<section class="mt-20">
    <div class="flex items-end justify-between gap-4 border-b border-border pb-4">
        <h2 class="text-2xl font-semibold tracking-tight text-foreground">{title}</h2>
        <span class="hidden text-xs tracking-[0.16em] text-muted-foreground uppercase sm:block">
            01
        </span>
    </div>
    <Reveal
        animation="slide-up"
        stagger
        staggerAmount={0.1}
        duration={0.6}
        class="mt-8 grid gap-px bg-border sm:grid-cols-2 lg:grid-cols-4"
    >
        {services.map((service) => <ServiceCard service={service} />)}
    </Reveal>
</section>
