---
import type { PricingPlan } from "../../types/pricing";

interface Props {
    title?: string;
    plans: PricingPlan[];
}

const { title = "Pricing", plans } = Astro.props;
---

<section class="mt-20">
    <h2 class="text-2xl font-semibold text-white">{title}</h2>
    <div class="mt-6 grid gap-6 md:grid-cols-3">
        {
            plans.map((plan) => (
                <div
                    class:list={[
                        "rounded-3xl border p-8 shadow-xl shadow-slate-950/20",
                        plan.highlighted
                            ? "border-sky-500 bg-slate-900"
                            : "border-slate-800 bg-slate-900/80",
                    ]}
                >
                    <h3 class="text-xl font-semibold text-white">{plan.name}</h3>
                    <p class="mt-2 text-3xl font-semibold text-white">
                        {plan.price}
                        {plan.period && (
                            <span class="text-sm font-normal text-slate-400"> / {plan.period}</span>
                        )}
                    </p>
                    <p class="mt-3 text-sm text-slate-400">{plan.description}</p>
                    <ul class="mt-4 space-y-2 text-sm text-slate-300">
                        {plan.features.map((feature) => (
                            <li class="flex gap-2">
                                <span class="text-sky-400">✓</span>
                                <span>{feature}</span>
                            </li>
                        ))}
                    </ul>
                    <a
                        href={plan.cta.href}
                        class:list={[
                            "mt-6 inline-flex w-full items-center justify-center rounded-full px-5 py-3 text-sm font-semibold transition",
                            plan.highlighted
                                ? "bg-sky-500 text-slate-950 hover:bg-sky-400"
                                : "border border-slate-700 text-white hover:border-slate-500",
                        ]}
                    >
                        {plan.cta.label}
                    </a>
                </div>
            ))
        }
    </div>
</section>
