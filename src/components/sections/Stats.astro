---
import type { StatsGroup } from "../../types/stats";

interface Props {
    group: StatsGroup;
}

const { group } = Astro.props;
---

<section class="mt-20">
    {
        group.title && (
            <div class="flex items-end justify-between gap-4 border-b border-border pb-4">
                <h2 class="text-2xl font-semibold tracking-tight text-foreground">{group.title}</h2>
            </div>
        )
    }
    {
        group.description && (
            <p class="mt-4 max-w-2xl text-sm leading-6 text-muted-foreground">{group.description}</p>
        )
    }
    <div class="mt-8 grid gap-px bg-border sm:grid-cols-2 lg:grid-cols-4">
        {
            group.items.map((item) => (
                <div class="bg-card p-6 text-center">
                    <p class="text-3xl font-semibold tracking-tight text-foreground">{item.value}</p>
                    <p class="mt-2 text-xs tracking-[0.08em] text-muted-foreground uppercase">
                        {item.label}
                    </p>
                </div>
            ))
        }
    </div>
</section>
