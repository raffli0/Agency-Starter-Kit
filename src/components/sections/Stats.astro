---
import type { StatsGroup } from "../../types/stats";

interface Props {
    group: StatsGroup;
}

const { group } = Astro.props;
---

<section class="mt-20">
    {group.title && <h2 class="text-2xl font-semibold text-white">{group.title}</h2>}
    {group.description && <p class="mt-3 max-w-2xl text-slate-300">{group.description}</p>}
    <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {
            group.items.map((item) => (
                <div class="rounded-3xl border border-slate-800 bg-slate-900/80 p-6 text-center shadow-xl shadow-slate-950/20">
                    <p class="text-3xl font-semibold text-white">{item.value}</p>
                    <p class="mt-1 text-sm text-slate-400">{item.label}</p>
                </div>
            ))
        }
    </div>
</section>
