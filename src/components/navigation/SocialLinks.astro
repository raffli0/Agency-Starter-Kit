---
import { socialConfig, socialLabels } from "../../config/social";

const entries = Object.entries(socialConfig) as [keyof typeof socialConfig, string][];
---

<nav class="flex gap-4" aria-label="Social links">
    {
        entries.map(([key, url]) => (
            <a
                href={url}
                target="_blank"
                rel="noopener noreferrer"
                class="text-sm text-slate-400 transition hover:text-white"
                aria-label={socialLabels[key]}
            >
                {socialLabels[key]}
            </a>
        ))
    }
</nav>
