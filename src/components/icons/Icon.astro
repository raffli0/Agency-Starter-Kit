---
interface Props {
    name: string;
    size?: number;
    class?: string;
    "aria-hidden"?: boolean;
}

const { name, size = 20, class: className = "", ...rest } = Astro.props;
---

<svg
    width={size}
    height={size}
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    class={className}
    aria-hidden={rest["aria-hidden"] ?? "true"}
    data-icon={name}
>
    <slot />
</svg>
