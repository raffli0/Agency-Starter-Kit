---
import type { ServiceItem } from "../../types/service";

interface Props {
    service: ServiceItem;
}

const { service } = Astro.props;
---

<article class="border border-border bg-card p-6 transition-colors duration-150 hover:border-foreground/20 sm:p-8">
    <h3 class="text-base font-semibold tracking-tight text-foreground sm:text-lg">{service.title}</h3>
    <p class="mt-3 text-sm leading-6 text-muted-foreground">{service.description}</p>
    {
        service.highlights && (
            <ul class="mt-4 flex flex-wrap gap-2">
                {service.highlights.map((item) => (
                    <li class="border border-border px-2.5 py-1 text-[11px] tracking-[0.06em] text-muted-foreground uppercase">
                        {item}
                    </li>
                ))}
            </ul>
        )
    }
</article>
