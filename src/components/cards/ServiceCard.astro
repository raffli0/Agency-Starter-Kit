---
import type { ServiceItem } from "../../types/service";

interface Props {
    service: ServiceItem;
}

const { service } = Astro.props;
---

<article
    class="border-border-primary bg-card hover:border-foreground/20 border p-6 transition-colors duration-150 sm:p-8"
>
    <h3 class="text-foreground text-base font-semibold tracking-tight sm:text-lg">
        {service.title}
    </h3>
    <p class="text-muted-foreground mt-3 text-sm leading-6">{service.description}</p>
    {
        service.highlights && (
            <ul class="mt-4 flex flex-wrap gap-2">
                {service.highlights.map((item) => (
                    <li class="border-border-primary text-muted-foreground border px-2.5 py-1 text-[11px] tracking-[0.06em] uppercase">
                        {item}
                    </li>
                ))}
            </ul>
        )
    }
</article>
