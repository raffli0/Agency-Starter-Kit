---
import type { ServiceItem } from "../../types/service";

interface Props {
    service: ServiceItem;
}

const { service } = Astro.props;
---

<article
    class="rounded-3xl border border-slate-800 bg-slate-900/80 p-6 shadow-xl shadow-slate-950/20 sm:p-8"
>
    <h3 class="text-lg font-semibold text-white sm:text-xl">{service.title}</h3>
    <p class="mt-3 text-sm text-slate-400">{service.description}</p>
    {
        service.highlights && (
            <ul class="mt-4 flex flex-wrap gap-2">
                {service.highlights.map((item) => (
                    <li class="rounded-full border border-slate-700 px-3 py-1 text-xs text-slate-300">
                        {item}
                    </li>
                ))}
            </ul>
        )
    }
</article>
