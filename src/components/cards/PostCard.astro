---
import type { BlogPost } from "../../types/blog";
import { formatDate } from "../../lib/date";
import { getLangFromUrl, localizePath } from "../../i18n/utils";

interface Props {
    post: BlogPost & { publishedAt: string | Date };
}

const { post } = Astro.props;
const locale = getLangFromUrl(Astro.url);
const href = localizePath(`/blog/${post.slug}`, locale);
const dateLocale = locale === "id" ? "id-ID" : "en-US";
---

<a
    href={href}
    class="block border border-border bg-card p-6 transition-colors duration-150 hover:border-foreground/20"
>
    <h2 class="text-base font-semibold tracking-tight text-foreground">{post.title}</h2>
    <p class="mt-3 text-sm leading-6 text-muted-foreground">{post.description}</p>
    <p class="mt-4 text-xs tracking-[0.08em] text-muted-foreground uppercase">
        {formatDate(post.publishedAt, dateLocale)}
    </p>
</a>
