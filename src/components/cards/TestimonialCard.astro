---
import type { Testimonial } from "../../types/testimonial";

interface Props {
    testimonial: Testimonial;
}

const { testimonial } = Astro.props;
---

<blockquote class="border border-border bg-card p-6">
    <p class="text-sm leading-6 text-muted-foreground">“{testimonial.quote}”</p>
    <footer class="mt-6 border-t border-border pt-4 text-xs tracking-[0.06em] text-muted-foreground uppercase">
        <span class="font-semibold text-foreground">{testimonial.author}</span>
        <span class="mx-1">—</span>
        {testimonial.role}, {testimonial.company}
    </footer>
</blockquote>
