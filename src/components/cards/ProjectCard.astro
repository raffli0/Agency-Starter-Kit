---
import type { ProjectItem } from "../../types/project";

interface Props {
    project: ProjectItem;
}

const { project } = Astro.props;
---

<article
    class="rounded-3xl border border-slate-800 bg-slate-900/80 p-8 shadow-xl shadow-slate-950/20"
>
    <div class="flex items-center justify-between gap-4">
        <h2 class="text-xl font-semibold text-white">
            {
                project.slug ? (
                    <a
                        href={`/projects/${project.slug}`}
                        class="transition hover:text-sky-300"
                    >
                        {project.title}
                    </a>
                ) : (
                    project.title
                )
            }
        </h2>
        <span class="rounded-full border border-slate-700 px-3 py-1 text-xs text-slate-300">
            {project.category}
        </span>
    </div>
    <p class="mt-3 text-slate-400">{project.description}</p>
    {project.year && <p class="mt-4 text-sm text-slate-500">{project.year}</p>}
</article>
