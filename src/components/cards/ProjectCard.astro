---
import type { ProjectItem } from "../../types/project";
import { getLangFromUrl, localizePath } from "../../i18n/utils";

interface Props {
    project: ProjectItem;
}

const { project } = Astro.props;
const locale = getLangFromUrl(Astro.url);
const projectHref = project.slug ? localizePath(`/projects/${project.slug}`, locale) : undefined;
---

<article
    class="border-border-primary bg-card hover:border-foreground/20 border p-0 transition-colors duration-150"
>
    {
        project.image && (
            <img
                src={project.image}
                alt=""
                width="400"
                height="300"
                loading="lazy"
                decoding="async"
                class="aspect-4/3 w-full object-cover"
            />
        )
    }
    <div class="p-8">
        <div class="flex items-start justify-between gap-4">
            <h2 class="text-foreground text-lg font-semibold tracking-tight">
            {
                projectHref ? (
                    <a href={projectHref} class="hover:text-brand transition-colors duration-150">
                        {project.title}
                    </a>
                ) : (
                    project.title
                )
            }
        </h2>
        <span
            class="border-border-primary text-muted-foreground shrink-0 border px-2.5 py-1 text-[11px] tracking-[0.06em] uppercase"
        >
            {project.category}
        </span>
    </div>
    <p class="text-muted-foreground mt-3 text-sm leading-6">{project.description}</p>
    {
        project.year && (
            <p class="text-muted-foreground mt-4 text-xs tracking-[0.08em] uppercase">
                {project.year}
            </p>
        )
    }
    </div>
</article>
