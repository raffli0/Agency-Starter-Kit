---
import type { ProjectItem } from "../../types/project";
import { getLangFromUrl, localizePath } from "../../i18n/utils";

interface Props {
    project: ProjectItem;
}

const { project } = Astro.props;
const locale = getLangFromUrl(Astro.url);
const projectHref = project.slug
    ? localizePath(`/projects/${project.slug}`, locale)
    : undefined;
---

<article class="border border-border bg-card p-8 transition-colors duration-150 hover:border-foreground/20">
    <div class="flex items-start justify-between gap-4">
        <h2 class="text-lg font-semibold tracking-tight text-foreground">
            {
                projectHref ? (
                    <a
                        href={projectHref}
                        class="transition-colors duration-150 hover:text-brand"
                    >
                        {project.title}
                    </a>
                ) : (
                    project.title
                )
            }
        </h2>
        <span class="shrink-0 border border-border px-2.5 py-1 text-[11px] tracking-[0.06em] text-muted-foreground uppercase">
            {project.category}
        </span>
    </div>
    <p class="mt-3 text-sm leading-6 text-muted-foreground">{project.description}</p>
    {
        project.year && (
            <p class="mt-4 text-xs tracking-[0.08em] text-muted-foreground uppercase">{project.year}</p>
        )
    }
</article>
