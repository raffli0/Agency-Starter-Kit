---
import { MessageCircle } from "lucide-astro";
import { socialConfig } from "../../config/social";
---

<a
    href={socialConfig.whatsapp}
    target="_blank"
    rel="noopener noreferrer"
    class="whatsapp-float"
    aria-label="Chat on WhatsApp"
    title="Chat on WhatsApp"
>
    <MessageCircle class="h-7 w-7" aria-hidden="true" />
</a>

<style is:global>
    @keyframes wa-reminder {
        0%, 100% { transform: scale(1); }
        10% { transform: scale(1.12); }
        20% { transform: scale(1); }
    }

    @keyframes wa-wave {
        0%, 100% { transform: rotate(0deg); }
        25% { transform: rotate(-12deg); }
        50% { transform: rotate(8deg); }
        75% { transform: rotate(-4deg); }
    }

    .wa-wave {
        animation: wa-wave 0.6s ease infinite;
    }

    .whatsapp-float {
        position: fixed;
        bottom: 1.5rem;
        right: 1.5rem;
        z-index: 50;
        display: flex;
        height: 3.5rem;
        width: 3.5rem;
        align-items: center;
        justify-content: center;
        border-radius: 9999px;
        background: #25D366;
        color: white;
        cursor: pointer;
        text-decoration: none;
        opacity: 0;
        transform: scale(0);
        will-change: transform;
        contain: layout style;
        transition: background 0.2s, transform 0.2s;
    }

    .whatsapp-float:hover {
        background: #20BD5A;
        transform: scale(1.1);
    }

    @media (prefers-reduced-motion: reduce) {
        .whatsapp-float {
            transition: none !important;
            opacity: 1 !important;
            transform: scale(1) !important;
        }
        .whatsapp-float:hover {
            transform: scale(1) !important;
        }
    }
</style>

<script>
    (function () {
        const el = document.querySelector(".whatsapp-float") as HTMLElement;
        if (!el) return;

        let reminderTimer: ReturnType<typeof setTimeout> | null = null;

        function clearReminder() {
            if (reminderTimer !== null) {
                clearTimeout(reminderTimer);
                reminderTimer = null;
            }
            el.style.animation = "";
        }

        function scheduleReminder() {
            clearReminder();
            reminderTimer = setTimeout(() => {
                el.style.animation = "wa-reminder 2s ease 1";
                el.addEventListener("animationend", () => {
                    el.style.animation = "";
                    scheduleReminder();
                }, { once: true });
            }, 25000);
        }

        el.animate(
            [
                { opacity: "0", transform: "scale(0)" },
                { opacity: "1", transform: "scale(1.15)", offset: 0.6 },
                { opacity: "1", transform: "scale(1)" },
            ],
            { duration: 600, easing: "cubic-bezier(0.34, 1.56, 0.64, 1)", fill: "forwards" }
        ).onfinish = () => {
            el.querySelector("svg")?.classList.add("wa-wave");
            scheduleReminder();
        };

        el.addEventListener("mouseenter", clearReminder);
        el.addEventListener("mouseleave", scheduleReminder);
        el.addEventListener("click", clearReminder);
    })();
</script>
