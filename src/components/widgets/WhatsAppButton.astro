---
import { MessageCircle } from "lucide-astro";
import { socialConfig } from "../../config/social";
---

<a
    href={socialConfig.whatsapp}
    target="_blank"
    rel="noopener noreferrer"
    class="whatsapp-float"
    aria-label="Chat on WhatsApp"
    title="Chat on WhatsApp"
>
    <MessageCircle class="h-7 w-7" aria-hidden="true" />
</a>

<style is:global>
    @keyframes wa-breathe {
        0%, 100% {
            transform: translateY(0);
        }
        50% {
            transform: translateY(-4px);
        }
    }

    @keyframes wa-wave {
        0%, 100% { transform: rotate(0deg); }
        25% { transform: rotate(-12deg); }
        50% { transform: rotate(8deg); }
        75% { transform: rotate(-4deg); }
    }

    @keyframes wa-bounce {
        0% { transform: scale(1); }
        40% { transform: scale(1.25); }
        70% { transform: scale(0.95); }
        100% { transform: scale(1.1); }
    }

    @keyframes wa-reminder {
        0%, 100% { transform: scale(1); }
        10% { transform: scale(1.12); }
        20% { transform: scale(1); }
    }

    .whatsapp-float {
        position: fixed;
        bottom: 1.5rem;
        right: 1.5rem;
        z-index: 50;
        display: flex;
        height: 3.5rem;
        width: 3.5rem;
        align-items: center;
        justify-content: center;
        border-radius: 9999px;
        background: #25D366;
        color: white;
        cursor: pointer;
        text-decoration: none;
        will-change: transform;
        contain: layout style;

        opacity: 0;
        transform: scale(0) translateY(2rem);
    }

    .whatsapp-float.wa-entered {
        opacity: 1;
        transform: scale(1);
        animation: wa-breathe 3.5s ease-in-out 0s infinite;
    }

    .whatsapp-float.wa-show-wave {
        animation: wa-wave 0.6s ease 3;
    }

    .whatsapp-float:hover {
        background: #20BD5A;
        animation: wa-bounce 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    @media (prefers-reduced-motion: reduce) {
        .whatsapp-float,
        .whatsapp-float.wa-entered,
        .whatsapp-float.wa-show-wave,
        .whatsapp-float:hover {
            animation: none !important;
            transition: none !important;
            opacity: 1 !important;
            transform: scale(1) !important;
        }
    }
</style>

<script>
    (function () {
        const el = document.querySelector(".whatsapp-float") as HTMLElement;
        if (!el) return;
        const btn = el;

        let reminderTimer: ReturnType<typeof setTimeout> | null = null;

        function runReminder() {
            stopReminder();
            reminderTimer = setTimeout(() => {
                btn.style.animation = "wa-reminder 2s ease 1";
                btn.classList.remove("wa-entered");
                setTimeout(() => {
                    btn.style.animation = "";
                    btn.classList.add("wa-entered");
                }, 2000);
                runReminder();
            }, 25000);
        }

        function stopReminder() {
            if (reminderTimer !== null) {
                clearTimeout(reminderTimer);
                reminderTimer = null;
            }
        }

        btn.animate(
            [
                { opacity: "0", transform: "scale(0) translateY(2rem)" },
                { opacity: "1", transform: "scale(1.15) translateY(-0.25rem)", offset: 0.6 },
                { opacity: "1", transform: "scale(1) translateY(0)" }
            ],
            { duration: 600, easing: "cubic-bezier(0.34, 1.56, 0.64, 1)", fill: "forwards" }
        ).onfinish = () => {
            btn.classList.add("wa-entered");
            btn.classList.add("wa-show-wave");
            setTimeout(() => btn.classList.remove("wa-show-wave"), 2000);
            setTimeout(runReminder, 3000);
        };

        btn.addEventListener("mouseenter", stopReminder);
        btn.addEventListener("mouseleave", () => {
            btn.classList.remove("wa-entered");
            setTimeout(() => {
                btn.classList.add("wa-entered");
                runReminder();
            }, 500);
        });
        btn.addEventListener("click", stopReminder);
    })();
</script>
